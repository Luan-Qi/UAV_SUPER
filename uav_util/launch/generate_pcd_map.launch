<launch>
    <!-- generate_pcd_map — 生成参数化几何体模拟点云地图 (PCD) -->
    <!-- 依赖: PCL, uav_util/pcd_map_generator_node -->
    <!-- 用法: roslaunch uav_util generate_pcd_map.launch shape_type:=cube -->
    <!-- 支持形状: cube(立方体) | sphere(球) | box_corridor(长方体走廊) | cylinder_corridor(圆柱走廊) -->
    <!--
      数据流:
        ROS params (shape_type, size, pose, noise)
               │
               ▼
        ┌──────────────┐    ┌──────────────┐    ┌──────────────┐
        │ ShapeFactory  │───▶│ ShapeBase    │───▶│ PostProcessing│
        │ (创建形状)     │    │ ::generate() │    │ (去质心/噪声)  │
        └──────────────┘    └──────────────┘    └──────┬───────┘
                                                       │
                                          ┌────────────┴────────────┐
                                          ▼                         ▼
                                     PCD 文件保存          sensor_msgs::PointCloud2
                                   (pcd_output_path)        (/generated_cloud)
    -->

    <!-- ===== 地图类型选择 ===== -->
    <!-- 形状类型: cube / sphere / box_corridor / cylinder_corridor -->
    <arg name="shape_type" default="cylinder_corridor"/>
    <!-- 点云类型: xyz / xyzi / xyzrgb -->
    <arg name="point_type" default="xyzi" />

    <!-- PCD 文件输出路径 -->
    <arg name="pcd_output_path"
        default="$(env HOME)/generated_map.pcd"/>

    <!-- ===== 通用参数 ===== -->
    <arg name="resolution" default="0.05"/>   <!-- 点云分辨率 [m] -->
    <arg name="thickness" default="0.1"/>    <!-- 壳体厚度 [m]（封闭体表面向内厚度） -->
    <arg name="publish_cloud" default="true"/> <!-- 是否发布点云到 topic -->

    <!-- 点云特殊参数 -->
    <arg name="intensity_dir" default="x"/>  <!-- 强度方向: x / y / z -->
    <arg name="point_color" default=""/>     <!-- 点云颜色字符串 (空=使用默认色) -->

    <!-- ===== 尺寸参数 ===== -->
    <!-- 立方体 / 长方体走廊 (shape_type=cube / box_corridor) -->
    <arg name="length" default="180.0"/>  <!-- X 方向长度 [m] -->
    <arg name="width"  default="50.0"/>   <!-- Y 方向宽度 [m] -->
    <arg name="height" default="6.0"/>   <!-- Z 方向高度 [m] -->

    <!-- 球体 / 圆柱走廊 (shape_type=sphere / cylinder_corridor) -->
    <arg name="radius" default="3.0"/>   <!-- 半径 [m] -->

    <!-- ===== 坐标系 ===== -->
    <arg name="center_x" default="-5.0"/>  <!-- 中心 X [m] -->
    <arg name="center_y" default="0.0"/>   <!-- 中心 Y [m] -->
    <arg name="center_z" default="3.0"/>   <!-- 中心 Z [m] -->

    <!-- 点云整体姿态 (先旋转 RPY，再平移 center) -->
    <arg name="roll"  default="0.0" />  <!-- [rad] -->
    <arg name="pitch" default="0.0" />  <!-- [rad] -->
    <arg name="yaw"   default="0.0" />  <!-- [rad] -->

    <!-- ===== 噪声参数 ===== -->
    <arg name="enable_noise" default="true"/>      <!-- 是否添加高斯噪声 -->
    <arg name="noise_std" default="0.01"/>        <!-- 噪声标准差 [m] -->

    <!-- 稀疏点 (模拟遮挡/采样不均) -->
    <arg name="enable_sparse" default="true"/>     <!-- 是否稀疏化 -->
    <arg name="sparse_keep_ratio" default="0.6"/>  <!-- 保留比例 (0~1) -->

    <!-- 孔洞 (模拟数据缺失) -->
    <arg name="enable_hole" default="false"/>      <!-- 是否开孔 -->
    <arg name="hole_x" default="10.0"/>           <!-- 孔洞中心 X [m] -->
    <arg name="hole_y" default="0.0"/>            <!-- 孔洞中心 Y [m] -->
    <arg name="hole_z" default="0.0"/>            <!-- 孔洞中心 Z [m] -->
    <arg name="hole_radius" default="1.5"/>       <!-- 孔洞半径 [m] -->

    <!-- ===== 使用示例 ===== -->
    <!-- 立方体: roslaunch uav_util generate_pcd_map.launch shape_type:=cube length:=10 width:=10 height:=5 -->
    <!-- 球体:   roslaunch uav_util generate_pcd_map.launch shape_type:=sphere radius:=5 -->
    <!-- 长方体走廊: roslaunch uav_util generate_pcd_map.launch shape_type:=box_corridor length:=100 width:=20 height:=6 -->
    <!-- 圆柱走廊: roslaunch uav_util generate_pcd_map.launch shape_type:=cylinder_corridor radius:=3 length:=200 -->
    <!-- 带噪声和孔洞: roslaunch uav_util generate_pcd_map.launch shape_type:=cube enable_noise:=true enable_hole:=true -->

    <!-- ===== 节点 ===== -->
    <!-- 根据参数生成 PCD 点云并保存到文件, 同时发布到 /generated_cloud 话题 -->
    <node pkg="uav_util"
          type="pcd_map_generator_node"
          name="pcd_map_generator"
          output="screen">

        <!-- 类型选择 -->
        <param name="shape_type" value="$(arg shape_type)"/>
        <param name="point_type" value="$(arg point_type)"/>

        <!-- PCD 输出 -->
        <param name="pcd_output_path" value="$(arg pcd_output_path)"/>

        <!-- 通用参数 -->
        <param name="resolution" value="$(arg resolution)"/>
        <param name="thickness" value="$(arg thickness)"/>
        <param name="publish_cloud" value="$(arg publish_cloud)"/>

        <!-- 尺寸参数（不用的在代码里会被忽略） -->
        <param name="length" value="$(arg length)"/>
        <param name="width"  value="$(arg width)"/>
        <param name="height" value="$(arg height)"/>
        <param name="radius" value="$(arg radius)"/>

        <!-- 坐标系旋转与原点 -->
        <param name="center_x" value="$(arg center_x)"/>
        <param name="center_y" value="$(arg center_y)"/>
        <param name="center_z" value="$(arg center_z)"/>
        <param name="roll" value="$(arg roll)"/>
        <param name="pitch" value="$(arg pitch)"/>
        <param name="yaw" value="$(arg yaw)"/>

        <!-- 噪声参数 -->
        <param name="enable_noise" value="$(arg enable_noise)"/>
        <param name="noise_std" value="$(arg noise_std)"/>
        <param name="enable_sparse" value="$(arg enable_sparse)"/>
        <param name="sparse_keep_ratio" value="$(arg sparse_keep_ratio)"/>
        <param name="enable_hole" value="$(arg enable_hole)"/>
        <param name="hole_x" value="$(arg hole_x)"/>
        <param name="hole_y" value="$(arg hole_y)"/>
        <param name="hole_z" value="$(arg hole_z)"/>
        <param name="hole_radius" value="$(arg hole_radius)"/>

    </node>

</launch>
