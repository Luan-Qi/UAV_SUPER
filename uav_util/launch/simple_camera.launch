<launch>
    <!-- simple_camera — V4L2 USB 摄像头 ROS 驱动 -->
    <!-- 依赖: OpenCV (VideoCapture), cv_bridge, image_transport, uav_util/simple_camera_driver -->
    <!-- 用法: roslaunch uav_util simple_camera.launch device_id:=0 width:=640 height:=480 fps:=30 -->
    <!--
      数据流:
        /dev/videoN ──▶ cv::VideoCapture ──▶ cv_bridge ──▶ image_transport
                                                               │
                                               ┌────────────────┴────────────────┐
                                               ▼                                 ▼
                                   /simple_camera/image_raw        /simple_camera/image_compressed
                                    (sensor_msgs::Image)            (sensor_msgs::CompressedImage)

      视频格式:
        MJPEG (mjpeg=true) — 硬件编码, 带宽低, 延迟略高, 适合高分辨率
        YUYV  (mjpeg=false) — 原始格式, 带宽高, 延迟低, 适合低分辨率
    -->

    <!-- ===== 设备配置 ===== -->
    <arg name="device_id" default="0" />    <!-- V4L2 设备 ID (0=/dev/video0, 1=/dev/video1, ...) -->
    <arg name="width" default="1280" />     <!-- 图像宽度 [pixel] -->
    <arg name="height" default="720" />     <!-- 图像高度 [pixel] -->
    <arg name="fps" default="30" />         <!-- 帧率 [Hz] -->

    <!-- ===== 图像格式 ===== -->
    <arg name="mjpeg" default="true" />     <!-- true=MJPEG 硬件编码 | false=YUYV 原始格式 -->

    <!-- ===== 使用示例 ===== -->
    <!-- 默认 USB 摄像头:  roslaunch uav_util simple_camera.launch -->
    <!-- 第二个摄像头:     roslaunch uav_util simple_camera.launch device_id:=2 -->
    <!-- 低分辨率高帧率:   roslaunch uav_util simple_camera.launch width:=640 height:=480 fps:=60 -->
    <!-- YUYV 低延迟:     roslaunch uav_util simple_camera.launch device_id:=0 mjpeg:=false width:=640 height:=480 -->
    <!-- 4K 摄像头:       roslaunch uav_util simple_camera.launch device_id:=0 width:=3840 height:=2160 fps:=15 -->

    <!-- ===== 节点 ===== -->
    <!-- 打开 V4L2 设备, 配置分辨率和帧率, 通过 image_transport 发布 raw + compressed 图像 -->
    <node pkg="uav_util" type="simple_camera_driver" name="my_webcam" output="screen">
        <param name="video_device_id" value="$(arg device_id)" />
        <param name="image_width" value="$(arg width)" />
        <param name="image_height" value="$(arg height)" />
        <param name="framerate" value="$(arg fps)" />
        <param name="use_mjpeg" value="$(arg mjpeg)" />

        <param name="camera_frame_id" value="camera_optical_frame" />
    </node>
</launch>
