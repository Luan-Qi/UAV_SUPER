<launch>
    <!-- local_planner — 局部规划（无全局地图的探索/巡航） -->
    <!--
      功能：启动 FAST-LIO 局部里程计 + EGO Planner 局部轨迹规划
            + 任务管理器 + PX4 控制器。不依赖全局地图，仅使用局部感知。

      系统架构：
        FAST-LIO (里程计)  ──→  EGO Planner (局部轨迹)
              │                       │
              └──── 里程计话题 ────────┘
                       │
              任务管理器 (mission_manger)
                       │
              PX4 控制器 (px4ctrl)  ──→  飞控

      依赖：fast_lio_uwb, ego_planner, uav_px4_ctrl
      用法：roslaunch uav_location local_planner.launch
    -->

    <!-- ===== 里程计话题 ===== -->
    <!-- 本地里程计话题（FAST-LIO 发布的 Odometry） -->
    <arg name="local_Odometry" default="/Odometry"/>

    <!-- ===== 起飞高度 [m] ===== -->
    <!-- 用于 PX4 控制器的起飞目标高度补偿 -->
    <param name="takeoff_height" value="0.3" />

    <!-- ===== FAST-LIO 局部里程计 (Livox Mid-360) ===== -->
    <!-- mapping_mid360: 在线里程计 + 局部点云建图 -->
    <include file="$(find fast_lio_uwb)/launch/mapping_mid360.launch" >
        <arg name="rviz" value="false" />
    </include>

    <!-- ===== PCD 保存 (关闭以节省 IO) ===== -->
    <param name="/pcd_save/pcd_save_en" value="false" />

    <!-- ===== EGO Planner 局部规划 ===== -->
    <!-- single_run_in_exp: 实验模式，无全局参考路径，纯局部探索/避障 -->
    <include file="$(find ego_planner)/launch/single_run_in_exp.launch" >
        <arg name="odom_topic" value="$(arg local_Odometry)"/>
    </include>

    <!-- ===== 静态 TF: world → camera_init ===== -->
    <!-- 对齐 FAST-LIO 的 camera_init 坐标系与世界系 -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="my_static_tf_publisher"
          args="0 0 0 0 0 0 world camera_init" />

    <!-- ===== 任务管理器 ===== -->
    <!-- 管理航点序列与任务状态机 -->
    <include file="$(find uav_px4_ctrl)/launch/mission_manger.launch" >
        <arg name="odom_topic" value="$(arg local_Odometry)"/>
        <arg name="goal_topic" value="/move_base_simple/goal"/>
        <arg name="distance_threshold" value="0.3"/>   <!-- 到达判定距离 [m] -->
        <arg name="mission_cycle" value="true"/>       <!-- 循环执行航点 -->
        <!-- 航点序列: [x, y, z] (FLU 机体坐标系) -->
        <arg name="waypoints" value="[2.0, 0.0, 0.3], [0.0, 0.0, 0.3]"/>
    </include>

    <!-- ===== PX4 控制器 ===== -->
    <!-- 接收 Odometry + 规划轨迹，输出 MAVROS 控制指令 -->
    <include file="$(find uav_px4_ctrl)/launch/px4ctrl.launch" />
</launch>
