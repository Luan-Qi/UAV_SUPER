<launch>
    <!-- global_planner_in_sim — 全局规划（仿真模式：无真实飞控/传感器） -->
    <!--
      功能：在 Gazebo/仿真环境中启动完整全局规划 + 控制流水线，与 global_planner.launch
            的区别在于：
            - 使用仿真话题重映射 (如 /drone_0_visual_slam/odom)
            - 启动 fast_lio_localization 做基于 ICP 的全局重定位
            - 启动 publish_initial_pose 提供初始位姿估计
            - 启动 transform_fusion 融合全局-局部定位
            - 启动 path_downsampler 对全局路径降采样

      系统数据流：
        激光雷达仿真  ──→ 点云 ──→ 全局定位 (ICP scan-to-map) → /map_to_odom
                             │                     │
        /Odometry(仿真) ─────┘                     │
                             │                     │
                             └──→ transform_fusion ─→ /localization
                                                           │
        全局地图 ──→ OctoMap ──→ A* 路径 ──→ Path Downsample
                                                   │
                                             EGO Planner ──→ Mission Manager ──→ 飞控仿真

      依赖：fast_lio_localization, transform_fusion, uav_planner, ego_planner, uav_px4_ctrl
      用法：roslaunch uav_location global_planner_in_sim.launch  \
                pcd_file:=/path/to/map.pcd
    -->

    <!-- ===== 话题重映射：仿真环境专用 ===== -->
    <remap from="/Odometry" to="/drone_0_visual_slam/odom"/>
    <remap from="/cloud_registered" to="/drone_0_pcl_render_node/cloud"/>

    <!-- ===== 全局地图点云文件 ===== -->
    <arg name="pcd_file" default="/home/orangepi/Documents/rospcd/dianguang_floor1_1_good_downsampled_downsampled.pcd"/>

    <!-- ===== RViz 开关 ===== -->
    <arg name="rviz" default="true" />

    <!-- ============================================================================ -->
    <!-- 1. 全局定位 (fast_lio_localization — 基于 GICP 的 scan-to-map 配准) -->
    <!-- ============================================================================ -->
    <!-- 名称"fast_lio_localization"源自原 Python 实现命名，实际使用 FastGICP 算法 -->
    <arg name="map_voxel_size" default="0.2" />        <!-- 地图降采样体素 [m] -->
    <arg name="scan_voxel_size" default="0.1" />       <!-- 扫描降采样体素 [m] -->
    <arg name="freq_localization" default="0.5" />     <!-- 全局定位频率 [Hz] -->
    <arg name="localization_th" default="0.95" />      <!-- ICP 收敛阈值 (伪 fitness) -->
    <arg name="fov" default="2.35" />                  <!-- LiDAR 视场角 [rad] (~135°) -->
    <arg name="fov_far" default="5.0" />               <!-- 最大有效距离 [m] -->
    <arg name="map_in_topic" default="/map" />         <!-- 全局地图输入话题 -->

    <node pkg="uav_location" type="fast_lio_localization" name="fast_lio_localization" output="screen" >
        <param name="map_voxel_size" value="$(arg map_voxel_size)" />
        <param name="scan_voxel_size" value="$(arg scan_voxel_size)" />
        <param name="freq_localization" value="$(arg freq_localization)" />
        <param name="localization_th" value="$(arg localization_th)" />
        <param name="fov" value="$(arg fov)" />
        <param name="fov_far" value="$(arg fov_far)" />
        <param name="map_in_topic" value="$(arg map_in_topic)" />
    </node>

    <!-- ============================================================================ -->
    <!-- 2. 初始位姿发布 (为全局定位提供初始猜测) -->
    <!-- ============================================================================ -->
    <arg name="init_x" default="0.0" />
    <arg name="init_y" default="-0.3" />
    <arg name="init_z" default="1.0" />
    <arg name="init_roll" default="0.0" />
    <arg name="init_pitch" default="0.0" />
    <arg name="init_yaw" default="0.0" />

    <node pkg="uav_location" type="publish_initial_pose" name="publish_initial_pose" output="screen"
        args="$(arg init_x) $(arg init_y) $(arg init_z) $(arg init_roll) $(arg init_pitch) $(arg init_yaw) " />

    <!-- ============================================================================ -->
    <!-- 3. 坐标融合 (transform_fusion) -->
    <!-- ============================================================================ -->
    <!-- 将全局 map_to_odom 与局部 Odometry 融合，发布 /localization -->
    <arg name="global_locatiation_hz" default="30.0" />  <!-- 融合发布频率 [Hz] -->
    <param name="takeoff_height" value="0.0" />           <!-- 仿真中不需要起飞补偿 -->

    <node pkg="uav_location" type="transform_fusion" name="transform_fusion" output="screen" >
        <param name="global_locatiation_hz" value="$(arg global_locatiation_hz)" />
    </node>

    <!-- ============================================================================ -->
    <!-- 4. 全局地图发布 (PCD → OctoMap) -->
    <!-- ============================================================================ -->
    <include file="$(find uav_planner)/launch/octomap_publisher.launch" >
        <arg name="pcd_file" value="$(arg pcd_file)"/>
    </include>

    <!-- ============================================================================ -->
    <!-- 5. A* 全局路径规划 -->
    <!-- ============================================================================ -->
    <arg name="octomap_topic" default="/octomap_full" />
    <arg name="start_pose_topic" default="/start_pose" />
    <arg name="goal_pose_topic" default="/goal_pose" />
    <arg name="enable_obstacle_show" default="true" />
    <arg name="inflater_size" default="2" />
    <arg name="planning_mode" default="1" />

    <include file="$(find uav_planner)/launch/astar_planner.launch" >
        <arg name="octomap_topic" value="$(arg octomap_topic)" />
        <arg name="start_pose_topic" value="$(arg start_pose_topic)" />
        <arg name="goal_pose_topic" value="$(arg goal_pose_topic)" />
        <arg name="enable_obstacle_show" value="$(arg enable_obstacle_show)" />
        <arg name="inflater_size" value="$(arg inflater_size)" />
        <arg name="planning_mode" value="$(arg planning_mode)" />
    </include>

    <!-- ============================================================================ -->
    <!-- 6. 全局路径降采样 (减少局部规划器参考点数量) -->
    <!-- ============================================================================ -->
    <node pkg="uav_planner" type="path_downsampler" name="path_downsampler">
        <param name="input_topic" value="/global_path_raw"/>
        <param name="output_topic" value="/global_path"/>
        <param name="mode" value="step"/>          <!-- step: 间隔采样; distance: 距离采样 -->
        <param name="step" value="10"/>            <!-- 间隔采样步长 (每隔10个点取1个) -->
        <param name="distance_thresh" value="2.0"/> <!-- 距离采样阈值 [m] -->
    </node>

    <!-- ============================================================================ -->
    <!-- 7. 局部轨迹规划 (EGO Planner — 仿真模式) -->
    <!-- ============================================================================ -->
    <include file="$(find ego_planner)/launch/single_run_in_sim_need_map.launch" >
        <arg name="pcd_file" value="$(arg pcd_file)"/>
        <arg name="init_x" value="$(arg init_x)"/>
        <arg name="init_y" value="$(arg init_y)"/>
        <arg name="init_z" value="$(arg init_z)"/>
    </include>

    <!-- ============================================================================ -->
    <!-- 8. 任务管理器 (航点序列) -->
    <!-- ============================================================================ -->
    <include file="$(find uav_px4_ctrl)/launch/mission_manger.launch" >
        <arg name="waypoints" value="[[52.0, -12.0, 1.0]*, [0.0, 0.0, 0.8]]"/>
    </include>

    <!-- ============================================================================ -->
    <!-- 9. RViz 可视化 -->
    <!-- ============================================================================ -->
    <group if="$(arg rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz1"
              args="-d $(find uav_location)/rviz/global_planner.rviz" />
    </group>
</launch>
