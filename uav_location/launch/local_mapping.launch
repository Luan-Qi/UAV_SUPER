<launch>
    <!-- local_mapping — 局部建图（在线 SLAM） -->
    <!--
      功能：启动 FAST-LIO 局部 SLAM 建图，同时可选启动 PX4 控制器。

      典型用途：
        - 手动遥控飞行采集环境点云（建图模式）
        - 通过 rosbag 回放数据离线建图

      依赖：fast_lio_uwb (mapping_mid360.launch), uav_px4_ctrl (px4ctrl.launch)
      用法：roslaunch uav_location local_mapping.launch use_sim_time:=true
    -->

    <!-- ===== 时间模式 ===== -->
    <!-- use_sim_time: true 时使用 /clock 仿真时间 (配合 rosbag 回放) -->
    <arg name="use_sim_time" default="false" />
    <param name="/use_sim_time" value="$(arg use_sim_time)" />

    <!-- ===== FAST-LIO 局部建图 (Livox Mid-360 LiDAR) ===== -->
    <!-- 启动激光里程计 + 在线建图，开启 RViz 可视化 -->
    <include file="$(find fast_lio_uwb)/launch/mapping_mid360.launch" >
        <arg name="rviz" value="true" />
    </include>

    <!-- ===== PX4 控制器 (仅实飞模式) ===== -->
    <!-- 仿真回放模式下不启动真实飞控 -->
    <group unless="$(arg use_sim_time)">
    	<include file="$(find uav_px4_ctrl)/launch/px4ctrl.launch" />
    </group>

    <!-- ===== Rosbag 回放 (仿真模式) ===== -->
    <!-- 从 NVMe 固态硬盘回放 bag，从第 66 秒开始，1 倍速 -->
    <group if="$(arg use_sim_time)">
	    <node name="playbag" pkg="rosbag" type="play" args="--clock /mnt/nvme/rosbag/float2.bag -r 1 -s 66" />
    </group>
</launch>
