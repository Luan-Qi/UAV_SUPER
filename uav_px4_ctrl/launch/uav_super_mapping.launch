<launch>
    <!-- uav_super_mapping — 建图模式启动文件（全局定位 + 局部里程计 + TF桥接） -->
    <!--
      功能：用于环境建图阶段的精简启动管线：
        1. 全局定位 (uav_localization: mapping_mid360)
        2. TF→Odometry 桥接 (convert_tf_to_odom.py)
        3. 局部里程计 (fast_lio: mapping_mid360)
      依赖：Livox Mid-360 激光雷达
      用法：roslaunch uav_px4_ctrl uav_super_mapping.launch

      与 uav_super_localization 的区别：
        - 不含规划/控制/任务管理模块
        - 定位配置使用 bag 模式 (use_bag=true)
        - 用于离线/在线建图阶段
    -->

    <!-- ===== 可视化 ===== -->
    <arg name="rviz" default="true" />  <!-- 是否启动 RViz -->

    <!-- ===== [1/3] 全局定位 ===== -->
    <!-- 注意: 建图模式下使用 mapping_mid360 (非 localization_mid360) -->
    <include file="$(find uav_localization)/launch/mapping_mid360.launch" >
        <arg name="use_bag" default="true" />  <!-- 使用 bag 数据 -->
        <arg name="rviz" default="true" />
    </include>

    <!-- ===== [2/3] TF → Odometry 桥接 ===== -->
    <node pkg="uav_px4_ctrl" type="convert_tf_to_odom.py" name="convert_tf_to_odom" output="screen"/>

    <!-- ===== [3/3] 局部里程计（供 PX4 飞控） ===== -->
    <include file="$(find fast_lio)/launch/mapping_mid360.launch" >
        <arg name="rviz" value="false" />
    </include>
</launch>
